# Copy this file to keystore.properties (gitignored) and fill in the real values.
# Required only for release/Play Store builds. See guide.md §7.
storeFile=<PLACEHOLDER_PATH_TO_KEYSTORE_JKS>
storePassword=<PLACEHOLDER_KEYSTORE_PASSWORD>
keyAlias=<PLACEHOLDER_KEY_ALIAS>
keyPassword=<PLACEHOLDER_KEY_PASSWORD>
