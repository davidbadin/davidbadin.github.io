# Template for KanaRead release signing.
# Copy this file to "keystore.properties" (same folder, no .example) on each PC,
# then fill in the real path and passwords. keystore.properties is gitignored
# so it never leaves the machine.

# Absolute path to your .jks keystore file. Adjust per PC.
#   Linux (Steam Deck/Distrobox):  /home/deck/.android-keystores/kanaread-upload.jks
#   Linux (other distros):         /home/<your-user>/.android-keystores/kanaread-upload.jks
#   Windows (Git Bash style path): C:/Users/<your-user>/.android-keystores/kanaread-upload.jks
storeFile=/home/deck/.android-keystores/kanaread-upload.jks

# Password you set when running `keytool -genkey` (step 1.2 of the publishing guide).
storePassword=REPLACE_WITH_YOUR_KEYSTORE_PASSWORD

# Alias name you passed to `keytool -alias kanaread-upload`. Keep this value.
keyAlias=kanaread-upload

# Same as storePassword if you used one password for both (recommended).
keyPassword=REPLACE_WITH_YOUR_KEY_PASSWORD
